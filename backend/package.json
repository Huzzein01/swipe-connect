{
  "name": "swipe-connect-backend",
  "version": "1.0.0",
  "description": "Backend for SwipeConnect job discovery app",
  "main": "dist/server.js",
  "engines": {
    "node": "20.x"
  },
  "scripts": {
    "start": "node dist/server.js",
    "dev": "ts-node-dev -r tsconfig-paths/register --respawn --transpile-only src/server.ts",
    "build": "tsc",
    "seed:startups": "ts-node -r tsconfig-paths/register src/scripts/seed-startups.ts",
    "test": "jest",
    "lint": "eslint . --ext .ts",
    "job-scraper": "ts-node -r tsconfig-paths/register src/scripts/start-job-scraper.ts"
  },
  "keywords": [
    "jobs",
    "linkedin",
    "swipe",
    "api"
  ],
  "author": "",
  "license": "ISC",
  "dependencies": {
    "axios": "^1.6.7",
    "bcryptjs": "^2.4.3",
    "cheerio": "^1.0.0-rc.12",
    "cors": "^2.8.5",
    "dotenv": "^16.4.5",
    "express": "^4.18.2",
    "express-session": "^1.18.0",
    "jsonwebtoken": "^9.0.2",
    "mongoose": "^8.1.3",
    "passport": "^0.7.0",
    "passport-linkedin-oauth2": "^2.0.0",
    "pdf-parse": "^1.1.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "^2.4.6",
    "@types/cheerio": "^0.22.35",
    "@types/cors": "^2.8.17",
    "@types/express": "^4.17.21",
    "@types/express-session": "^1.18.2",
    "@types/jest": "^29.5.12",
    "@types/jsonwebtoken": "^9.0.5",
    "@types/node": "^20.11.24",
    "@types/passport": "^1.0.16",
    "@types/passport-linkedin-oauth2": "^1.5.5",
    "@types/pdf-parse": "^1.1.5",
    "@typescript-eslint/eslint-plugin": "^7.0.1",
    "@typescript-eslint/parser": "^7.0.1",
    "eslint": "^8.56.0",
    "jest": "^29.7.0",
    "ts-jest": "^29.1.2",
    "ts-node": "^10.9.2",
    "ts-node-dev": "^2.0.0",
    "tsconfig-paths": "^4.2.0",
    "typescript": "^5.3.3"
  }
}
